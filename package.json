{
	"name": "@kevinpeckham/barkup",
	"version": "0.2.0",
	"description": "Author typed trees as HTML. A config-driven grammar codec with byte-for-byte id preservation, declared attribute coercion, and round-trip guarantees \u2014 designed for humans and LLM agents authoring the same markup.",
	"author": "Kevin Peckham",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"import": "./dist/testing.js"
		},
		"./patch": {
			"types": "./dist/patch.d.ts",
			"import": "./dist/patch.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"scripts": {
		"audit": "bunx fallow audit",
		"build": "tsc -p tsconfig.build.json",
		"check": "tsc --noEmit",
		"format": "bunx biome format --write .",
		"health": "bunx fallow health",
		"lint": "bunx biome lint --write .",
		"prepublishOnly": "bun run check && bun test && bun run build",
		"test": "bun test"
	},
	"keywords": [
		"html",
		"ast",
		"serialization",
		"markup",
		"llm",
		"agents",
		"typed-tree",
		"grammar",
		"codec",
		"round-trip"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevinpeckham/barkup.git"
	},
	"homepage": "https://www.lightningjar.com/blog/ast-as-html",
	"peerDependencies": {
		"fast-check": ">=3.0.0"
	},
	"peerDependenciesMeta": {
		"fast-check": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"fallow": "^3.0.0",
		"fast-check": "^3.23.0",
		"linkedom": "^0.18.5",
		"typescript": "^5.7.0",
		"varlock": "^1.9.0"
	},
	"engines": {
		"node": ">=18"
	},
	"bugs": {
		"url": "https://github.com/kevinpeckham/barkup/issues"
	},
	"publishConfig": {
		"access": "public"
	}
}
